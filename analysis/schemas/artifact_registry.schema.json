{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArtifactRegistry",
  "type": "object",
  "required": [
    "session_id",
    "artifacts"
  ],
  "properties": {
    "session_id": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "track",
          "kind",
          "canonical_path",
          "sha256",
          "size_bytes"
        ],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "track": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "canonical_path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer"
          },
          "source_path": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          },
          "provenance": {
            "type": "object"
          }
        }
      }
    }
  }
}
