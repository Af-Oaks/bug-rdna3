{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CorrelationSummary",
  "type": "object",
  "required": [
    "session_id",
    "pipeline_count",
    "shader_module_count",
    "confidence_counts"
  ],
  "properties": {
    "session_id": {
      "type": "string"
    },
    "pipeline_count": {
      "type": "integer"
    },
    "shader_module_count": {
      "type": "integer"
    },
    "confidence_counts": {
      "type": "object",
      "properties": {
        "exact": {
          "type": "integer"
        },
        "strong": {
          "type": "integer"
        },
        "weak": {
          "type": "integer"
        },
        "unresolved": {
          "type": "integer"
        }
      }
    }
  }
}
